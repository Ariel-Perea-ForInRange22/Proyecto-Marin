<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />

    <application
        android:usesCleartextTraffic="true"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DevCore"
        tools:targetApi="31">

        <!-- Splash Activity - Pantalla de inicio -->
        <activity
            android:name="com.devcore.uat.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.DevCore">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Activity -->
        <activity
            android:name="com.devcore.uat.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.DevCore" />

        <!-- Register Activity -->
        <activity
            android:name="com.devcore.uat.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.DevCore" />

        <!-- Pending Activity -->
        <activity
            android:name="com.devcore.uat.PendingActivity"
            android:exported="false"
            android:theme="@style/Theme.DevCore" />

        <!-- Home Activity -->
        <activity
            android:name="com.devcore.uat.HomeActivity"
            android:exported="false"
            android:theme="@style/Theme.DevCore" />

        <!-- Bus Tracking Activity -->
        <activity
            android:name="com.devcore.uat.BusTrackingActivity"
            android:exported="false"
            android:theme="@style/Theme.DevCore" />

        <!-- Profile Activity -->
        <activity
            android:name="com.devcore.uat.ProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.DevCore" />

        <!-- Marketplace Activity -->
        <activity
            android:name="com.devcore.uat.MarketplaceActivity"
            android:exported="false"
            android:theme="@style/Theme.DevCore" />

        <!-- Comunidades Activity -->
        <activity
            android:name="com.devcore.uat.ComunidadesActivity"
            android:exported="false"
            android:theme="@style/Theme.DevCore" />

        <!-- Comunidad Mural Activity -->
        <activity
            android:name="com.devcore.uat.ComunidadMuralActivity"
            android:exported="false"
            android:theme="@style/Theme.DevCore"
            android:windowSoftInputMode="adjustResize" />

        <!-- User Search Activity -->
        <activity
            android:name="com.devcore.uat.UserSearchActivity"
            android:exported="false"
            android:theme="@style/Theme.DevCore"
            android:windowSoftInputMode="adjustResize" />

        <!-- User Profile Posts Activity -->
        <activity
            android:name="com.devcore.uat.UserProfilePostsActivity"
            android:exported="false"
            android:theme="@style/Theme.DevCore" />

        <!-- Settings Activity -->
        <activity
            android:name="com.devcore.uat.SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.DevCore"
            android:windowSoftInputMode="adjustResize" />

    </application>

</manifest>
